{
  "name": "herramienta-corte-sprites",
  "private": true,
  "version": "0.1.0",
  "description": "Herramienta local para recortar sprite sheets y exportar sprites individuales.",
  "author": "ByteShark-dev <byteshark098@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByteShark-dev/Herramienta-corte-sprites.git"
  },
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "desktop": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win nsis portable"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.byteshark.spritecutter",
    "productName": "Sprite Sheet Cutter",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SpriteSheetCutter-${version}-win-${arch}.${ext}",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "artifactName": "SpriteSheetCutter-Setup-${version}-win-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Sprite Sheet Cutter"
    }
  }
}
